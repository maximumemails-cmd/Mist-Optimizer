<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:PCOptimizer.Controls"
        xmlns:views="using:PCOptimizer.Views"
        xmlns:vm="using:PCOptimizer.ViewModels"
        x:Class="PCOptimizer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Mist"
        Icon="/Assets/mist-logo.png"
        Width="1360"
        Height="860"
        MinWidth="860"
        MinHeight="620"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:HomePageViewModel}" x:DataType="vm:HomePageViewModel">
            <views:HomePageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RamCleanerPanelViewModel}" x:DataType="vm:RamCleanerPanelViewModel">
            <views:RamCleanerPanelView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PcSpecsPageViewModel}" x:DataType="vm:PcSpecsPageViewModel">
            <views:PcSpecsPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OptimizationPanelViewModel}" x:DataType="vm:OptimizationPanelViewModel">
            <views:OptimizationPanelView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <Border Background="{DynamicResource AppShellBrush}">
            <Grid ColumnDefinitions="260,*" MinHeight="0">
                <controls:StarFieldControl IsPaused="{Binding AreAnimationsPaused}" Grid.ColumnSpan="2" Opacity="0.32" />

                <Border Grid.Column="0"
                        Margin="18"
                        Padding="18"
                        CornerRadius="24"
                        Background="{DynamicResource AppPanelBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        BoxShadow="0 22 70 #33000000">
                    <Grid RowDefinitions="Auto,*,Auto" MinHeight="0">
                        <StackPanel Spacing="12">
                            <Image Source="{Binding Brand.LogoUri}"
                                   Width="88"
                                   Height="88"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left" />
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Brand.AppName}" Foreground="{DynamicResource AppTextBrush}" FontSize="26" FontWeight="SemiBold" />
                                <TextBlock Text="Premium system utility" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Pages}" Margin="0,28,0,18">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AppPageViewModel">
                                    <Border Padding="12"
                                            Margin="0,0,0,8"
                                            CornerRadius="14"
                                            Background="{DynamicResource AppPanelAltBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AppTextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="Active"
                                                       Foreground="{DynamicResource AppAccentBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsCurrent}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="2" Spacing="12">
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                <Button Content="&lt;" Command="{Binding PreviousPageCommand}" FontSize="20" HorizontalAlignment="Stretch" />
                                <Border Grid.Column="1" Padding="12,8" CornerRadius="12" Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="{Binding PageIndicatorText}" Foreground="{DynamicResource AppTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                </Border>
                                <Button Grid.Column="2" Content="&gt;" Command="{Binding NextPageCommand}" FontSize="20" HorizontalAlignment="Stretch" />
                            </Grid>
                            <StackPanel Spacing="5">
                                <TextBlock Text="Global progress" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" />
                                <ProgressBar Minimum="0" Maximum="1" Value="{Binding GlobalProgress}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="*" Margin="0,18,18,18" MinHeight="0">
                    <Border
                            CornerRadius="26"
                            Background="{DynamicResource AppPanelBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="18"
                            ClipToBounds="True"
                            MinHeight="0"
                            BoxShadow="0 24 80 #44000000">
                        <TransitioningContentControl Content="{Binding CurrentPage.Content}">
                            <TransitioningContentControl.PageTransition>
                                <CrossFade Duration="0:0:0.22" />
                            </TransitioningContentControl.PageTransition>
                        </TransitioningContentControl>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsRestartPromptOpen}"
                Background="#AA000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Width="460"
                    Padding="24"
                    CornerRadius="22"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 24 70 #66000000">
                <StackPanel Spacing="16">
                    <Image Source="{Binding Brand.LogoUri}" Width="72" Height="72" Stretch="Uniform" HorizontalAlignment="Left" />
                    <TextBlock Text="Restart Required" Foreground="{DynamicResource AppTextBrush}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="Some optimizations require a restart to finish applying." Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Content="Restart Later" Command="{Binding RestartLaterCommand}" />
                        <Button Grid.Column="1"
                                Content="Restart Now"
                                Command="{Binding RestartNowCommand}"
                                Background="{DynamicResource MistGlowBrush}"
                                Foreground="#06111F"
                                FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
