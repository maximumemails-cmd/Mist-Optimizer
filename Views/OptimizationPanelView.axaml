<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:PCOptimizer.Models"
             xmlns:vm="using:PCOptimizer.ViewModels"
             x:Class="PCOptimizer.Views.OptimizationPanelView"
             x:DataType="vm:OptimizationPanelViewModel">
    <Border Classes="card"
            Background="{DynamicResource AppCardBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="22"
            Padding="18"
            BoxShadow="0 18 45 #33000000">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" MinHeight="0">
            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AppTextBrush}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="13" TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,14,0,10">
                <ComboBox ItemsSource="{Binding CategoryFilters}"
                          SelectedItem="{Binding SelectedFilter}"
                          MinWidth="150"
                          Background="{DynamicResource AppPanelAltBrush}"
                          Foreground="{DynamicResource AppTextBrush}" />
                <Button Grid.Column="1" Content="Select All" Command="{Binding SelectAllCommand}" Margin="8,0,0,0" />
                <Button Grid.Column="2" Content="Deselect All" Command="{Binding DeselectAllCommand}" Margin="8,0,0,0" />
            </Grid>

            <ProgressBar Grid.Row="2" Minimum="0" Maximum="1" Value="{Binding Progress}" Margin="0,0,0,12" />

            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateText}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <ItemsControl ItemsSource="{Binding FilteredCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:OptimizationCategory">
                                <Border Background="{DynamicResource AppPanelBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel Spacing="10">
                                        <CheckBox IsThreeState="True"
                                                  IsChecked="{Binding SelectionState, Mode=TwoWay}"
                                                  Content="{Binding Name}"
                                                  FontWeight="SemiBold" />
                                        <ItemsControl ItemsSource="{Binding Actions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:OptimizationAction">
                                                    <Border Background="{DynamicResource AppPanelAltBrush}"
                                                            CornerRadius="12"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                            <CheckBox Grid.RowSpan="3"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      IsEnabled="{Binding IsEnabled}"
                                                                      VerticalAlignment="Top"
                                                                      Margin="0,2,10,0" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Name}"
                                                                       Foreground="{DynamicResource AppTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Grid.Row="1"
                                                                       Grid.Column="1"
                                                                       Text="{Binding Description}"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,8" />
                                                            <WrapPanel Grid.Row="2" Grid.Column="1">
                                                                <Border Background="{DynamicResource AppAccentBrush}" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding Category}" Foreground="White" FontSize="11" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding RiskBadge}" Foreground="{DynamicResource AppTextBrush}" FontSize="11" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding RestartBadge}" Foreground="{DynamicResource AppTextBrush}" FontSize="11" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding AdminBadge}" Foreground="{DynamicResource AppTextBrush}" FontSize="11" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AppSuccessBrush}" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding ImplementationBadge}" Foreground="{DynamicResource AppTextBrush}" FontSize="11" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="7,3" Margin="0,0,6,4">
                                                                    <TextBlock Text="{Binding RevertBadge}" Foreground="{DynamicResource AppTextBrush}" FontSize="11" />
                                                                </Border>
                                                            </WrapPanel>
                                                            <TextBlock Grid.Row="3"
                                                                       Grid.Column="1"
                                                                       Text="{Binding DisabledReason}"
                                                                       Foreground="{DynamicResource AppWarningBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,6,0,0" />
                                                            <TextBlock Grid.Row="4"
                                                                       Grid.Column="1"
                                                                       Text="{Binding ExactAction}"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,3,0,0" />
                                                            <TextBlock Grid.Row="5"
                                                                       Grid.Column="1"
                                                                       Text="{Binding UndoAction}"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,3,0,0" />
                                                            <TextBlock Grid.Row="6"
                                                                       Grid.Column="1"
                                                                       Text="{Binding Source, StringFormat='Source: {0}'}"
                                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,3,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="4" Text="{Binding StatusText}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" Margin="0,12,0,8" TextWrapping="Wrap" />
            <Grid Grid.Row="5" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Content="Preview Changes"
                        Command="{Binding PreviewSelectedCommand}"
                        HorizontalAlignment="Stretch" />
                <Button Grid.Column="1"
                        Content="Revert Selected"
                        Command="{Binding RevertSelectedCommand}"
                        HorizontalAlignment="Stretch" />
                <Button Grid.Column="2"
                        Content="Apply Selected"
                        Command="{Binding ApplySelectedCommand}"
                        HorizontalAlignment="Stretch"
                        Background="{DynamicResource AppAccentBrush}"
                        Foreground="White"
                        FontWeight="SemiBold" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
