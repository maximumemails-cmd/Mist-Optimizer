<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:PCOptimizer.Views"
             xmlns:vm="using:PCOptimizer.ViewModels"
             x:Class="PCOptimizer.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <Grid x:Name="LayoutRoot"
          RowDefinitions="Auto,*"
          ColumnDefinitions="*,*"
          RowSpacing="16"
          ColumnSpacing="18"
          MinHeight="0">
        <views:RamCleanerPanelView x:Name="RamPanel"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   DataContext="{Binding RamCleanerPanel}" />
        <views:OptimizationPanelView x:Name="RestartPanel"
                                     Grid.Row="1"
                                     Grid.Column="0"
                                     DataContext="{Binding RestartPanel}" />
        <views:OptimizationPanelView x:Name="NoRestartPanel"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     DataContext="{Binding NoRestartPanel}" />
    </Grid>
</UserControl>
